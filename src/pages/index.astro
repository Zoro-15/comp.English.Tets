---
import '../styles/global.css';
import TestPage from '../components/TestPage';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>ENGLISH MOCK TESTS | Online Competitive Practice Exam</title>
    <meta 
      name="description" 
      content="Prepare for competitive English exams with our interactive mock tests. Instant scoring, detailed breakdowns, and time-tracking features." 
    />
    <meta name="keywords" content="English Mock Test, IELTS Prep, TOEFL Practice, GRE Vocabulary, Grammar Quiz, Competitive Exams" />
    <meta name="author" content="ENGLISH MOCK TESTS" />
    
    <!-- Google Fonts for Minimalist Academic Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400..700;1,400..700&family=Source+Sans+3:ital,wght@0,300..700;1,300..700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-brand-bg text-brand-text antialiased font-source">
    <!-- Hydrate the React Main Page on the client side -->
    <TestPage client:load />
  </body>
</html>
